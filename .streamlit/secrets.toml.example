# ============================================================
# Storytime Studio — Streamlit secrets template
# Copy to .streamlit/secrets.toml (local) or paste into
# Streamlit Cloud → App settings → Secrets.
# ============================================================

# --- Database ---
MONGODB_URI = "mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB = "children_book_generator"

# --- Cashfree Payments ---
# IMPORTANT: keys and environment MUST match.
# Sandbox keys -> CASHFREE_ENV = "sandbox"; Production keys -> "production"
CASHFREE_APP_ID = ""
CASHFREE_SECRET_KEY = ""
CASHFREE_ENV = "production"

# Public URL of your deployed app (used as the payment return URL)
APP_BASE_URL = "https://your-app.streamlit.app"

# --- Email (OTP sign-in codes) ---
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "you@gmail.com"
SMTP_PASSWORD = ""
SMTP_FROM = "Storytime Studio <you@gmail.com>"

# Show OTP on screen when SMTP is unavailable (DEV ONLY — never in production)
ALLOW_DEV_OTP = "false"

# --- Google sign-in (Streamlit native OIDC) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.streamlit.app/oauth2callback
[auth]
redirect_uri = "https://your-app.streamlit.app/oauth2callback"
cookie_secret = "GENERATE_A_LONG_RANDOM_STRING"
client_id = ""
client_secret = ""
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

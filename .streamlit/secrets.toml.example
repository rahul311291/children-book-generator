# ============================================================
# Storytime Studio — Streamlit secrets template
# Copy to .streamlit/secrets.toml (local) or paste into
# Streamlit Cloud → App settings → Secrets.
# ============================================================

# --- Database ---
MONGODB_URI = "mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB = "children_book_generator"

# --- Cashfree Payments ---
# IMPORTANT: keys and environment MUST match.
# Sandbox keys -> CASHFREE_ENV = "sandbox"; Production keys -> "production"
CASHFREE_APP_ID = ""
CASHFREE_SECRET_KEY = ""
CASHFREE_ENV = "production"

# Public URL of your deployed app (used as the payment return URL)
APP_BASE_URL = "https://your-app.streamlit.app"

# --- Email (OTP sign-in codes) ---
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "you@gmail.com"
SMTP_PASSWORD = ""
SMTP_FROM = "Storytime Studio <you@gmail.com>"

# Show OTP on screen when SMTP is unavailable (DEV ONLY — never in production)
ALLOW_DEV_OTP = "false"

# --- Google sign-in (Streamlit native OIDC) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.streamlit.app/oauth2callback
[auth]
redirect_uri = "https://your-app.streamlit.app/oauth2callback"
cookie_secret = "GENERATE_A_LONG_RANDOM_STRING"
client_id = ""
client_secret = ""
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# --- AI generation backend: Vertex AI ONLY ---
# All text and image generation runs through Vertex AI. The previous
# GEMINI_API_KEY and OPENROUTER_API_KEY paths have been removed.
#
# 1. In GCP Console -> IAM -> Service Accounts, create a service account
#    with the Vertex AI User role.
# 2. Generate a JSON key, copy the contents into the triple-quoted
#    block below. Don't change the embedded \n in private_key — TOML
#    keeps them as-is and the JSON parser converts them back to real
#    newlines on the other side.
#
# Sidebar values (admin paste) take priority over these secrets, then
# env vars, then this file. Non-admin users inherit the admin's setup.

VERTEX_PROJECT_ID = ""
VERTEX_LOCATION   = "us-central1"
GOOGLE_SERVICE_ACCOUNT_JSON = """
{
  "type": "service_account",
  "project_id": "",
  "private_key_id": "",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "",
  "client_id": "",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": ""
}
"""
